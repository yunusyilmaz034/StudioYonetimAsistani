# Studio Operating System — LOCAL / EMULATOR environment.
# Copy to .env.local (gitignored). Everything here runs against the Firebase Emulator
# Suite with a fixed demo project id — no real project, no real secret, no real money.
#
# Deployed environments (staging, prod) do NOT read this file. They take their configuration
# from `apphosting.yaml`, and their secrets from Google Secret Manager. That separation is the
# point: a value that exists in this repository can never be a secret, and `server/secrets.ts`
# refuses to start a deployed environment that is missing one rather than falling back to the
# development value printed below.

# Fixed demo project id used by the client and Admin SDKs against the emulator.
NEXT_PUBLIC_FIREBASE_PROJECT_ID=demo-sos
FIREBASE_PROJECT_ID=demo-sos

# Client SDK: connect to the Auth emulator (default on in non-production).
NEXT_PUBLIC_FIREBASE_EMULATOR=true
NEXT_PUBLIC_FIREBASE_AUTH_EMULATOR_URL=http://127.0.0.1:9099

# Admin SDK: setting these makes the Admin SDK talk to the emulators, no creds.
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
FIRESTORE_EMULATOR_HOST=127.0.0.1:8080

# ── Secrets ─────────────────────────────────────────────────────────────────────────────────
# Optional locally: `server/secrets.ts` supplies a development value when they are absent, and
# ONLY when the environment is not a deployed one. They are listed here because a secret nobody
# has written down is a secret nobody provisions — and the QR key was, until v1.26, read by the
# code and declared nowhere.
#
# QR_TOKEN_SECRET signs the 60-second check-in token. In staging and production it comes from
# Secret Manager (see apphosting.yaml). QR_TOKEN_SECRET_PREVIOUS is set only during a rotation.
# QR_TOKEN_SECRET=
# QR_TOKEN_SECRET_PREVIOUS=

# Resend — the real e-mail transport (owner decision, 2026-07-13). Absent locally, the pipeline
# falls back to the console provider: the message is rendered and logged, and nothing leaves the
# building. That is a deliberate development behaviour, never a production one.
# RESEND_API_KEY=
# EMAIL_FROM=noreply@pilatesfitnessbyisil.com
