# Studio Operating System — local/emulator environment.
# Copy to .env.local (gitignored). This milestone (v1.5) runs ONLY against the
# Firebase Emulator Suite with a fixed demo project id — no real project or secrets.

# Fixed demo project id used by the client and Admin SDKs against the emulator.
NEXT_PUBLIC_FIREBASE_PROJECT_ID=demo-sos
FIREBASE_PROJECT_ID=demo-sos

# Client SDK: connect to the Auth emulator (default on in non-production).
NEXT_PUBLIC_FIREBASE_EMULATOR=true
NEXT_PUBLIC_FIREBASE_AUTH_EMULATOR_URL=http://127.0.0.1:9099

# Admin SDK: setting these makes the Admin SDK talk to the emulators, no creds.
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
