# dependencies
node_modules/
.pnpm-store/

# build output
dist/
lib/
# …but never a source `src/lib/` directory (packages emit build output to a
# package-root `lib/`; app source lives under `src/lib/` and must be tracked).
!**/src/lib/
*.tsbuildinfo
.next/
out/

# test / coverage
coverage/

# firebase
.firebase/
firebase-export-*/
firebase-debug.log
firestore-debug.log
ui-debug.log
.seed/

# migration artifacts (raw exports are archived to Cloud Storage, never committed)
tools/migration/*.local.*
tools/migration/data/
# The reports NAME MEMBERS AND QUOTE THEIR PHONE NUMBERS — that is what makes them useful to a
# human fixing the source file, and exactly why they may never enter version control.
tools/migration/reports/

# env / secrets
.env
.env.*
!.env.example
# The functions' production sender. An identity, not a credential — see the file's own header.
!apps/functions/.env.studio-yonetim-prod

# editor / OS
.DS_Store
*.log

# PayTR vendor reference docs (read-only, not part of the repo)
docs/PayTR Linkle Ödeme/
docs/PayTR IFrame API/
