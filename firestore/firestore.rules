rules_version = '2';

// The tenant perimeter (Doc 3 §8, AD-15). Three load-bearing properties:
//   1. A client can READ only within its own studio (token.studioId == sid). A
//      cross-tenant read is a path you cannot construct, not a filter you forget.
//   2. Only a STAFF principal can read at all (D11, v1.21). A member's token carries
//      studioId + memberId + role:'member' and matches NO read rule here: the member
//      portal is server-rendered, and every byte a member sees passes through a Server
//      Action that derived her identity from the session cookie. This is why the portal
//      cannot leak: there is no client-SDK path to leak through.
//   3. A client can WRITE exactly one thing: create a whitelisted /commands doc as
//      itself — and only staff may do even that. Every trusted state write (members,
//      entitlements, /products, …) goes through a server-side Server Action on the Admin
//      SDK, which BYPASSES these rules — that authorization is enforced by
//      requireTenantContext() / requireMemberContext(), and the role-guard tests verify it
//      separately.
//
// Why role-gating reads is not optional: before v1.21 every authenticated principal was
// staff, so `tenant()` alone was safe. The instant a member is issued a studioId claim,
// `allow read: if tenant()` would hand her every member's name, phone and birth date, every
// entitlement, and every payment in the studio — straight from the client SDK, with no UI
// involved. The perimeter, not the UI, is what protects that data.
service cloud.firestore {
  match /databases/{database}/documents {

    match /studios/{sid} {

      function signedIn() { return request.auth != null; }
      function tenant()   { return signedIn() && request.auth.token.studioId == sid; }
      function role()     { return request.auth.token.role; }

      // Staff, for the one thing staff may WRITE: a whitelisted command.
      function staff() {
        return tenant() && (role() == 'owner' || role() == 'receptionist' || role() == 'trainer');
      }

      // The ONLY principals that may READ through the client SDK.
      //
      // A member is deliberately absent — she reads nothing directly, ever — and from v1.27 **so is
      // a TRAINER**. She is staff, and she is also the person least entitled to the studio's data:
      // she needs her own classes and the names of the women in them, and nothing else. She gets all
      // of it from the server, filtered, through `/my-classes`.
      //
      // The whole staff app reads through the Admin SDK on the server; NOTHING in it reads Firestore
      // from the browser. So denying a trainer every read costs the product nothing and closes a real
      // hole: until now her token could be pointed straight at Firestore and used to pull every
      // member's phone number and every payment in the studio.
      function desk() {
        return tenant() && (role() == 'owner' || role() == 'receptionist');
      }

      // ── Events: append-only log. Owner-only read; never client-writable. ──
      match /events/{eventId} {
        allow read:  if desk() && role() == 'owner';
        allow write: if false;
      }

      // ── Commands: the ONLY client write in the entire rule set (AD-15). Staff only —
      //    a member never writes a command. Her bookings are Server Actions (they allocate
      //    a scarce resource), and her check-in QR is verified server-side (D16). ──
      match /commands/{cmdId} {
        allow create: if staff()
          && request.resource.data.actor.id == request.auth.uid
          && request.resource.data.type in ['checkIn.record', 'attendance.mark']
          && request.resource.data.status == 'pending'
          && cmdId == request.resource.data.id;
        allow read:   if staff() && resource.data.actor.id == request.auth.uid;
        allow update, delete: if false;
      }

      // ── Everything else in the studio: DESK-readable, never client-writable. ──
      //    Events and commands are excluded here so their stricter rules above are
      //    not widened by this one (Firestore ORs all matching allow rules).
      //    A trainer matches NO read rule at all — the same posture as a member.
      match /{col}/{docId} {
        allow read:  if desk() && !(col in ['events', 'commands']);
        allow write: if false;
      }
    }

    // Anything outside /studios/{sid} is denied by the absence of a rule.
  }
}
