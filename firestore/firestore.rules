rules_version = '2';

// SCAFFOLD PLACEHOLDER — default deny.
//
// The real rule set is specified in Doc 3 §8 and built in the security milestone
// (Doc 8 Day 4): tenant-scoped reads, role gating, the single `allow create` on
// /commands, immutable /events, and the emulator tests that prove studio A cannot
// read studio B. Until then, nothing is readable or writable. Deny-by-default is
// the only safe starting posture, and it keeps this file honest: it makes no
// promise the code has not yet kept.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
