rules_version = '2';

// The tenant perimeter (Doc 3 §8, AD-15). Two load-bearing properties:
//   1. A client can READ only within its own studio (token.studioId == sid). A
//      cross-tenant read is a path you cannot construct, not a filter you forget.
//   2. A client can WRITE exactly one thing: create a whitelisted /commands doc as
//      itself. Every trusted state write (members, entitlements, /products, …) goes
//      through a server-side Server Action on the Admin SDK, which BYPASSES these
//      rules — that authorization is enforced by requireTenantContext(), and the
//      role-guard tests verify it separately.
service cloud.firestore {
  match /databases/{database}/documents {

    match /studios/{sid} {

      function signedIn() { return request.auth != null; }
      function tenant()   { return signedIn() && request.auth.token.studioId == sid; }
      function role()     { return request.auth.token.role; }

      // ── Events: append-only log. Owner-only read; never client-writable. ──
      match /events/{eventId} {
        allow read:  if tenant() && role() == 'owner';
        allow write: if false;
      }

      // ── Commands: the ONLY client write in the entire rule set (AD-15). ──
      match /commands/{cmdId} {
        allow create: if tenant()
          && request.resource.data.actor.id == request.auth.uid
          && request.resource.data.type in ['checkIn.record', 'attendance.mark']
          && request.resource.data.status == 'pending'
          && cmdId == request.resource.data.id;
        allow read:   if tenant() && resource.data.actor.id == request.auth.uid;
        allow update, delete: if false;
      }

      // ── Everything else in the studio: tenant-readable, never client-writable. ──
      //    Events and commands are excluded here so their stricter rules above are
      //    not widened by this one (Firestore ORs all matching allow rules).
      match /{col}/{docId} {
        allow read:  if tenant() && !(col in ['events', 'commands']);
        allow write: if false;
      }
    }

    // Anything outside /studios/{sid} is denied by the absence of a rule.
  }
}
