{
  "firestore": {
    "rules": "firestore/firestore.rules",
    "indexes": "firestore/firestore.indexes.json"
  },
  "functions": [
    {
      "source": "apps/functions",
      "codebase": "default",
      "predeploy": ["pnpm --filter @studio/functions build"],
      "ignore": [
        "node_modules",
        ".git",
        "*.local",
        "src",
        "test",
        "dist",
        "tsconfig.json",
        "build.mjs",
        "*.tsbuildinfo"
      ]
    }
  ],
  "emulators": {
    "auth": { "port": 9099 },
    "firestore": { "port": 8080 },
    "functions": { "port": 5001 },
    "pubsub": { "port": 8085 },
    "ui": { "enabled": true }
  }
}
